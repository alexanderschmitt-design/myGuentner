{
  "name": "mygpc",
  "version": "1.0.0",
  "description": "Güntner Product Configurator — Nuxt 3 SSR on Vercel + Supabase (Postgres/pgvector + Auth + Storage). All API routes ported to Nitro.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "npm --prefix nuxt run dev",
    "build": "npm --prefix nuxt run build",
    "preview": "npm --prefix nuxt run preview",
    "typecheck": "npm --prefix nuxt run typecheck",
    "gen-types": "npm --prefix nuxt run gen:gpceu-types",
    "probe-dms": "node rag/probe-dms.js",
    "probe-dms-2": "node rag/probe-dms-2.js",
    "probe-gpceu": "node rag/probe-gpceu.js",
    "probe-mapping": "node rag/probe-mapping.js",
    "probe-datasheet": "node rag/probe-datasheet-mapping.js",
    "build-gpc-parameters": "node rag/build-gpc-parameters.js",
    "create-user": "node scripts/create-user.mjs",
    "migrate-local-to-supabase": "node scripts/migrate-local-to-supabase.mjs",
    "smoke": "node -e \"const base=process.env.SMOKE_BASE||'https://myguentner.vercel.app';(async()=>{for(const p of ['/login','/api/dms/health','/api/gpc-eu/health']){try{const r=await fetch(base+p);console.log('['+r.status+'] '+p);}catch(e){console.log('[ERR] '+p,e.message);}}})();\""
  },
  "keywords": [
    "guentner",
    "product-configurator",
    "nuxt",
    "vercel",
    "supabase",
    "rag"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "dotenv": "^16.4.7"
  }
}
