# ============================================================
# myGPC RAG Server — Environment Configuration (TEMPLATE)
# ============================================================
# Diese Datei in `.env` kopieren und mit den echten Werten füllen.
# `.env` ist via .gitignore ausgeschlossen — keine Keys ins Repo!
#
#   cp .env.example .env
#   # dann .env mit echten Werten bearbeiten

# --- Server ---
PORT=3001

# --- Embeddings (Vektor-Erzeugung) ---
# Modus: "local" (TF-IDF, offline, kein Key) | "openai"
# - local:  funktioniert ohne API-Key. Reicht für deutsche/englische Tests, aber bei
#           mehrsprachigen Dokumenten (z. B. französisches Manual + deutsche Frage)
#           ist die Trefferqualität schwach.
# - openai: braucht echten OPENAI_API_KEY (NICHT der Anthropic-Key — andere Plattform).
#           Multilingual, deutlich höhere Score-Qualität.
RAG_EMBEDDING_MODE=local
RAG_EMBEDDING_MODEL=text-embedding-3-small

# Echter OpenAI-Key (NUR wenn RAG_EMBEDDING_MODE=openai)
# Holen unter: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- LLM "Bella" (Antwort-Generierung) ---
# Anthropic Claude Sonnet 4.6 — generiert die Antworten im Chatbot
# Holen unter: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- DMS d.velop d.3one ---
# Hauptzugang. Test-URL nur eintragen, wenn die Test-Umgebung erreichbar ist
# (war zum letzten Probe-Stand offline — HTTP 503).
DMS_BASE_URL=https://dms-prod.guentner.com
DMS_BASE_URL_PROD=https://dms-prod.guentner.com
# DMS_BASE_URL_TEST=https://dms-test.guentner.com

# Repository-UUID — der ID-Teil in /dms/r/{UUID}/...
# Aus der Beispiel-URL des DMS-Admins ablesbar.
DMS_REPOSITORY_ID=

# Auth-Methode — "bearer" für d.velop d.3one bei Güntner verifiziert
# Andere mögliche Werte (falls Setup wechselt): "session" | "basic"
DMS_AUTH_MODE=bearer

# Bei DMS_AUTH_MODE=bearer: das Bearer-Token aus dem DMS-Admin-Portal
# Bei DMS_AUTH_MODE=session: AuthSessionId-Cookie-Wert
# Bei DMS_AUTH_MODE=basic: base64(user:password)
DMS_API_KEY=

# --- GPC.EU Customer API ("Maike PCAPI") ---
# Reverse-Proxy in rag/gpceu-proxy.js mountet alle Endpoints unter /api/gpc-eu/*.
# Spec: rag/gpceu_swagger.json (43 Endpoints, Version 2026.9-318, Test-Backend).
# Health-Check nach Server-Start:  GET http://localhost:3001/api/gpc-eu/health
# Lokaler Smoke-Test:               npm run probe-gpceu

# Pflicht — Basis-URL der API (ohne trailing slash)
# Test-Backend:  https://apieu-calc-test.azurewebsites.net    (Auth: X-API-Key)
# Prod-Backend:  https://api.portal-guentner.com/emea/api/gpc (Auth: JWT/Login)
GPCEU_BASE_URL=https://apieu-calc-test.azurewebsites.net

# Auth-Variante A: API-Key (Test-Backend — empfohlen für Entwicklung)
# Wird als X-API-Key-Header gesendet. Kein Login, kein Refresh, kein Caching.
# Alias-Name GUENTNER_API_KEY wird ebenfalls akzeptiert.
GPCEU_API_KEY=

# Auth-Variante B: statisches JWT (Prod-Backend, Read-Only-Tests)
# Wenn gesetzt UND GPCEU_API_KEY leer ist: wird unverändert als Bearer mitgegeben.
GPCEU_JWT=

# Auth-Variante C: Auto-Login mit Service-Account (Prod-Backend)
# Login-Endpoint wird aus GPCEU_BASE_URL abgeleitet (entfernt /emea/api/gpc und
# hängt /identity/login an); per GPCEU_LOGIN_URL überschreibbar.
GPCEU_EMAIL=
GPCEU_PASSWORD=
GPCEU_LOGIN_URL=

# Pfad-Prefix für probe-gpceu (Default für Test-Backend). Beim Wechsel auf Prod leer setzen.
# Override-ENV-Variable: GPCEU_PATH_PREFIX=api/GPCDataQuery (Default) bzw. "" für Prod-Root.

# Health-Endpoint, den der Proxy gegen die API ruft (Default für Test-Backend).
# Beim Wechsel auf Prod-Backend auf gpcversion ändern.
GPCEU_HEALTH_PATH=api/GPCDataQuery/gpcversion

# Optional — Request-Timeout in Millisekunden (Default 30000)
GPCEU_TIMEOUT_MS=30000

# Mock-Modus — wenn "1", liefert der Proxy Fixture-Daten aus rag/gpceu-mock.js
# statt echte Upstream-Calls. Nützlich während der Wartezeit auf den Service-Account.
# Beim ersten Live-Test auf "0" oder Zeile entfernen.
GPCEU_MOCK=0

# --- Nuxt-App (Phase 3 — myGPS-Wizard als Vue-SSR) ---
# Nitro-Server läuft auf eigenem Port; Express proxied /app/* dorthin.
# Beim Build via `npm run build` (im nuxt/-Ordner) entsteht nuxt/.output/server/index.mjs.
NUXT_PORT=3002
NUXT_TARGET=http://localhost:3002

# Server-seitige API-Base-URL für SSR-Calls (interner Loopback zum Express).
# Im Browser wird stattdessen /api verwendet — siehe nuxt/nuxt.config.ts runtimeConfig.public.
NUXT_API_BASE_INTERNAL=http://localhost:3001/api

# --- Supabase (Phase B — Datenbank, Storage, Auth) ---
# Aus Supabase Dashboard → Project Settings → API. Beim Rebrand hat Supabase
# die Keys umbenannt: publishable = anon (browser-safe), secret = service_role
# (server-only, bypasses Row Level Security).
#
# URL wird aus der Project-ID abgeleitet: https://<project-id>.supabase.co
SUPABASE_URL=
SUPABASE_PROJECT_ID=

# Browser-safe. Wird ins Nuxt-Client-Bundle inline'd.
SUPABASE_PUBLISHABLE_KEY=

# Server-only. NIE ins Repo, NIE ins Client-Bundle. Auf Vercel als Encrypted Env.
SUPABASE_SECRET_KEY=

# Datenbank-Passwort — nur für direkten DB-Zugriff (psql, Supabase CLI).
# Von der App wird es nicht gelesen; hier nur zur Referenz.
SUPABASE_PSW=
